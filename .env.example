# Required core application values for hosted environments.
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=https://ccm.example.com

# Optional. Without this key, intake generation uses the deterministic fallback
# and still requires review. OPENAI_MODEL defaults to gpt-4o-mini when enabled.
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional sandbox billing foundation. All values must remain Stripe test mode.
# Checkout needs STRIPE_SECRET_KEY, NEXT_PUBLIC_APP_URL, and at least one Price ID.
# Webhook processing additionally needs STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PLATFORM_PRICE_ID=
STRIPE_PATIENT_PRICE_ID=

# Optional patient email delivery. SMS is intentionally adapter-only until a provider is selected.
RESEND_API_KEY=
PATIENT_EMAIL_FROM=CCM Assistant <checkins@example.com>

# Optional. Supabase invite links otherwise use the documented one-hour expiry.
STAFF_INVITATION_TTL_MINUTES=60

# Optional development-only persona and UX audit controls. Production builds always ignore this flag.
NEXT_PUBLIC_CCM_AUDIT_MODE=false
